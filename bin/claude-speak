#!/usr/bin/env python3
"""
claude-speak: PTY wrapper for Claude Code with streaming TTS.
Passes all output through unchanged while feeding text to macOS `say`.
Controlled by ~/.claude-tts-enabled flag file.
"""

import fcntl
import os
import pty
import queue
import re
import select
import signal
import struct
import subprocess
import sys
import termios
import threading
import tty

TTS_FLAG = os.path.expanduser("~/.claude-tts-enabled")

# ── Text cleaning ────────────────────────────────────────────────────────────

ANSI = re.compile(
    r"\x1B(?:[@-Z\\-_]|\[[0-9;]*[ -/]*[@-~]|\][^\x07\x1B]*(?:\x07|\x1B\\))"
)
SPINNER = re.compile(r"[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏⣾⣽⣻⢿⡿⣟⣯⣷]")
BOX = re.compile(r"[─│┌┐└┘├┤┬┴┼╭╮╰╯╴╵╶╷▸◂▴▾◆●○►◄▲▼◀▶]")
JSON_LINE = re.compile(r"^\s*[\[{\]},]")
TOOL_LINE = re.compile(
    r"^\s*(?:✓|✗|⚠|●|►|▸)?\s*(?:Running|Reading|Writing|Editing|Searching|"
    r"Fetching|Using|Calling|Tool|Done|Error)\b",
    re.IGNORECASE,
)
PERMISSION_UI = re.compile(r"Do you want to|Allow Claude to|Approve\?", re.IGNORECASE)


def clean(raw: bytes) -> str:
    try:
        text = raw.decode("utf-8", errors="replace")
    except Exception:
        return ""
    text = ANSI.sub("", text)
    text = SPINNER.sub("", text)
    text = BOX.sub("", text)
    lines = []
    for line in text.split("\n"):
        s = line.strip()
        if not s:
            lines.append("")
            continue
        if JSON_LINE.match(s):
            continue
        if TOOL_LINE.match(s):
            continue
        if PERMISSION_UI.search(s):
            continue  # hook handles permission prompts
        lines.append(line)
    return "\n".join(lines)


# ── TTS worker ───────────────────────────────────────────────────────────────


class TTSWorker:
    """Buffers streamed text into sentences and speaks them sequentially."""

    def __init__(self):
        self._q: queue.Queue = queue.Queue()
        self._buf = ""
        self._in_code = False
        self._ticks = ""
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()

    # -- public ---------------------------------------------------------------

    def feed(self, text: str):
        if not os.path.exists(TTS_FLAG):
            return
        for ch in text:
            # Track triple-backtick code fences
            if ch == "`":
                self._ticks += ch
                if len(self._ticks) == 3:
                    if not self._in_code:
                        self._in_code = True
                        self._flush()
                        self._q.put("code block")
                    else:
                        self._in_code = False
                    self._ticks = ""
                    self._buf = ""
                continue
            else:
                if self._ticks:
                    if not self._in_code:
                        self._buf += self._ticks
                    self._ticks = ""

            if self._in_code:
                continue

            self._buf += ch

            # Flush on sentence boundaries
            if ch in ".!?" and len(self._buf) > 12:
                self._flush()
            elif ch == "\n" and len(self._buf) > 40:
                self._flush()

    def flush_and_stop(self):
        self._flush()
        self._q.put(None)
        self._thread.join(timeout=120)

    # -- private --------------------------------------------------------------

    def _flush(self):
        text = self._buf.strip()
        self._buf = ""
        if text and len(text) > 3:
            self._q.put(text)

    def _run(self):
        while True:
            item = self._q.get()
            if item is None:
                return
            try:
                subprocess.run(["say", item], timeout=120)
            except Exception:
                pass


# ── PTY helpers ──────────────────────────────────────────────────────────────


def find_real_claude() -> str | None:
    my = os.path.realpath(os.path.abspath(__file__))
    for d in os.environ.get("PATH", "").split(":"):
        if not d:
            continue
        candidate = os.path.join(d, "claude")
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            if os.path.realpath(candidate) != my:
                return candidate
    return None


def set_winsize(fd: int, rows: int, cols: int):
    fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))


def get_winsize() -> tuple[int, int]:
    try:
        return os.get_terminal_size()
    except Exception:
        return (24, 80)


# ── Main ─────────────────────────────────────────────────────────────────────


def main():
    claude = find_real_claude()
    if not claude:
        sys.stderr.write("claude-speak: claude binary not found in PATH\n")
        sys.exit(1)

    # TTS disabled → transparent exec, zero overhead
    if not os.path.exists(TTS_FLAG):
        os.execv(claude, [claude] + sys.argv[1:])
        return

    tts = TTSWorker()
    rows, cols = get_winsize()
    master_fd, slave_fd = pty.openpty()
    set_winsize(master_fd, rows, cols)

    def _sigwinch(sig, frame):
        try:
            r, c = get_winsize()
            set_winsize(master_fd, r, c)
        except Exception:
            pass

    signal.signal(signal.SIGWINCH, _sigwinch)

    pid = os.fork()
    if pid == 0:
        # Child → become claude
        os.close(master_fd)
        os.setsid()
        fcntl.ioctl(slave_fd, termios.TIOCSCTTY, 0)
        for fd in (0, 1, 2):
            os.dup2(slave_fd, fd)
        if slave_fd > 2:
            os.close(slave_fd)
        os.execv(claude, [claude] + sys.argv[1:])
        sys.exit(1)

    os.close(slave_fd)
    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    old_attr = termios.tcgetattr(stdin_fd)
    try:
        tty.setraw(stdin_fd)
        while True:
            try:
                rlist, _, _ = select.select([master_fd, stdin_fd], [], [], 0.05)
            except (ValueError, select.error):
                break

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    break
                if not data:
                    break
                os.write(stdout_fd, data)
                tts.feed(clean(data))

            if stdin_fd in rlist:
                try:
                    data = os.read(stdin_fd, 1024)
                except OSError:
                    break
                if data:
                    os.write(master_fd, data)

    finally:
        termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_attr)
        tts.flush_and_stop()
        try:
            os.waitpid(pid, 0)
        except ChildProcessError:
            pass


if __name__ == "__main__":
    main()
