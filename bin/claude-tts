#!/usr/bin/env bash
# claude-tts: helper for the claude-tts accessibility tool
# Usage: claude-tts <toggle|status|speak-nth|stop>

set -euo pipefail

TTS_FLAG="$HOME/.claude-tts-enabled"
CMD="${1:-help}"
shift || true

# ── Clean text for TTS ───────────────────────────────────────────────────────
_clean() {
  python3 - "$@" << 'PYEOF'
import sys, re

text = sys.stdin.read()
# Code blocks → marker
text = re.sub(r'```[\s\S]*?```', ' code block. ', text)
# Inline code → strip backticks
text = re.sub(r'`[^`\n]{1,120}`', '', text)
# Markdown headers
text = re.sub(r'^#{1,6}\s+', '', text, flags=re.MULTILINE)
# Bold / italic
text = re.sub(r'\*{1,3}([^*\n]+)\*{1,3}', r'\1', text)
# URLs
text = re.sub(r'https?://\S+', 'link', text)
# Table rows
text = re.sub(r'\|[^\n]+\|', '', text)
# Collapse extra whitespace
text = re.sub(r'[ \t]{3,}', ' ', text)
text = re.sub(r'\n{3,}', '\n\n', text)
print(text.strip())
PYEOF
}

# ── Find most recent Claude transcript ──────────────────────────────────────
_find_transcript() {
  python3 -c "
import glob, os
files = glob.glob(os.path.expanduser('~/.claude/projects/**/*.jsonl'), recursive=True)
if files:
    print(max(files, key=os.path.getmtime))
"
}

# ── Extract Nth-last assistant message from transcript ──────────────────────
_extract_nth() {
  local transcript="$1"
  local n="$2"
  python3 - "$transcript" "$n" << 'PYEOF'
import sys, json

transcript = sys.argv[1]
n = int(sys.argv[2])
messages = []

with open(transcript) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            role = obj.get('role', '')
            if role != 'assistant':
                continue
            content = obj.get('content', '')
            if isinstance(content, str) and content.strip():
                messages.append(content)
            elif isinstance(content, list):
                parts = [
                    c.get('text', '') for c in content
                    if isinstance(c, dict) and c.get('type') == 'text'
                ]
                text = ' '.join(parts).strip()
                if text:
                    messages.append(text)
        except (json.JSONDecodeError, KeyError):
            pass

if len(messages) >= n:
    sys.stdout.write(messages[-n])
PYEOF
}

# ── Commands ─────────────────────────────────────────────────────────────────

case "$CMD" in
  toggle)
    if [ -f "$TTS_FLAG" ]; then
      rm "$TTS_FLAG"
      echo "Speaking mode: OFF"
    else
      touch "$TTS_FLAG"
      echo "Speaking mode: ON"
      say "Speaking mode on" &
    fi
    ;;

  status)
    if [ -f "$TTS_FLAG" ]; then
      echo "ON"
    else
      echo "OFF"
    fi
    ;;

  speak-nth)
    # speak-nth [transcript|auto] N
    TRANSCRIPT="${1:-auto}"
    N="${2:-1}"

    if [ "$TRANSCRIPT" = "auto" ]; then
      TRANSCRIPT="$(_find_transcript)"
    fi

    if [ -z "$TRANSCRIPT" ] || [ ! -f "$TRANSCRIPT" ]; then
      echo "claude-tts: no transcript found" >&2
      exit 1
    fi

    TEXT="$(_extract_nth "$TRANSCRIPT" "$N")"

    if [ -z "$TEXT" ]; then
      echo "claude-tts: no response at position -$N" >&2
      exit 1
    fi

    CLEANED="$(echo "$TEXT" | _clean)"
    say "$CLEANED"
    ;;

  stop)
    pkill -x say 2>/dev/null || true
    echo "Stopped"
    ;;

  help|*)
    echo "Usage: claude-tts <toggle|status|speak-nth [transcript] N|stop>" >&2
    exit 1
    ;;
esac
