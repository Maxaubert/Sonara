#!/usr/bin/env bash
# Self-contained: run the plugin's own src with no installed 'sonara'.
here="$(cd "$(dirname "$0")" && pwd)"
root="$(cd "$here/.." && pwd)"
export PYTHONPATH="$root/src${PYTHONPATH:+:$PYTHONPATH}"
# Windows (Git Bash): prefer the real `python` (e.g. Python 3.14) — `python3`
# there is often a Microsoft Store stub. Fall back to any python3 on PATH.
py="$(command -v python || command -v python3 || true)"
exec "$py" -m sonara.cli "$@"
